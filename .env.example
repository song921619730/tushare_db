# Tushare DB 环境变量模板
# 复制本文件为 .env 后填入真实值；.env 已在 .gitignore，绝不提交

# Tushare Pro 10k 积分账号 token（在 tushare.pro 个人主页获取）
TUSHARE_TOKEN=replace_with_your_token

# ClickHouse 三用户密码（生成方式：python -c "import secrets; print(secrets.token_urlsafe(32))"）
CH_PIPELINE_PASSWORD=replace_with_random_32_chars
CH_AI_READER_PASSWORD=replace_with_random_32_chars
CH_GRAFANA_PASSWORD=replace_with_random_32_chars

# 可选：覆盖默认连接参数
# CH_HOST=clickhouse
# CH_HTTP_PORT=8123
# CH_NATIVE_PORT=9000
# MCP_HOST=0.0.0.0
# MCP_PORT=7800
