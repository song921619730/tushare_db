    {
      "id": 9,
      "title": "Top Error Interfaces (Last 24h)",
      "type": "bargauge",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "ClickHouse" },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "ClickHouse" },
          "format": "table",
          "rawSql": "SELECT interface, count() AS errors FROM _meta.sync_state FINAL WHERE status IN ('failed', 'partial') AND last_success_at > now() - INTERVAL 24 HOUR GROUP BY interface ORDER BY errors DESC LIMIT 10",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 }
    },
    {
      "id": 10,
      "title": "Sync State Summary",
      "type": "piechart",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "ClickHouse" },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "ClickHouse" },
          "format": "table",
          "rawSql": "SELECT status, count() AS cnt FROM _meta.sync_state FINAL GROUP BY status",
          "refId": "A"
