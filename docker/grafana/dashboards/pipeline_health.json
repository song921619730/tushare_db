              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 16 }
    },
    {
      "id": 7,
      "title": "Running Units",
      "type": "stat",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "ClickHouse" },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "ClickHouse" },
          "format": "table",
