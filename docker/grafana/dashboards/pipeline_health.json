    {
      "id": 8,
      "title": "Done Units",
      "type": "stat",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "ClickHouse" },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "ClickHouse" },
          "format": "table",
          "rawSql": "SELECT count() AS done FROM _meta.sync_state FINAL WHERE status = 'done'",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
