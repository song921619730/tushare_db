  "panels": [
    {
      "id": 1,
      "title": "Bucket Utilization (Normal)",
      "type": "timeseries",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "ClickHouse" },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "ClickHouse" },
          "format": "time_series",
          "rawSql": "SELECT toStartOfMinute(started_at) AS time, count() / 60.0 AS rpm FROM _meta.api_calls WHERE started_at > now() - INTERVAL 1 HOUR GROUP BY time ORDER BY time",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 400 },
              { "color": "red", "value": 475 }
            ]
          },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Bucket Utilization (Special)",
      "type": "timeseries",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "ClickHouse" },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "ClickHouse" },
          "format": "time_series",
          "rawSql": "SELECT toStartOfMinute(started_at) AS time, count() / 60.0 AS rpm FROM _meta.api_calls WHERE started_at > now() - INTERVAL 1 HOUR AND bucket = 'special' GROUP BY time ORDER BY time",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 240 },
              { "color": "red", "value": 285 }
            ]
          },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "id": 3,
      "title": "API Call Rate (Last 24h)",
      "type": "timeseries",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "ClickHouse" },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "ClickHouse" },
          "format": "time_series",
          "rawSql": "SELECT toStartOfHour(started_at) AS time, count() AS calls FROM _meta.api_calls WHERE started_at > now() - INTERVAL 24 HOUR GROUP BY time ORDER BY time",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "id": 4,
      "title": "API p99 Latency",
      "type": "timeseries",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "ClickHouse" },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "ClickHouse" },
          "format": "time_series",
          "rawSql": "SELECT toStartOfHour(started_at) AS time, quantile(0.99)(duration_ms) AS p99_ms FROM _meta.api_calls WHERE started_at > now() - INTERVAL 24 HOUR GROUP BY time ORDER BY time",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    },
    {
      "id": 5,
      "title": "Failed Units",
      "type": "stat",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "ClickHouse" },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "ClickHouse" },
          "format": "table",
          "rawSql": "SELECT count() AS failed FROM _meta.sync_state FINAL WHERE status = 'failed'",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 16 }
    },
    {
      "id": 6,
